# ═══════════════════════════════════════════════════════════════
# SupplySense Docker Environment — COPY THIS TO backend/.env
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL=sqlite:///./data/SupplySense.db

# JWT Auth
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Ollama — Local AI (primary provider)
# Install: https://ollama.com  |  Run: ollama run gemma4:latest
# Uses host.docker.internal so Docker containers can reach your local Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=120

# Google Gemini API — fallback #1 (free tier — https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter — fallback #2 (free tier — https://openrouter.ai/)
OPENROUTER_API_KEY=your-openrouter-key-here

# Serper Web Search — intelligence layer (https://serper.dev/)
SERPER_API_KEY=your-serper-api-key-here

# WhatsApp Bot (Docker internal URL — auto-set by docker-compose)
WHATSAPP_BOT_URL=http://localhost:3001

# App Settings
APP_NAME=SupplySense
APP_VERSION=1.0.0
DEBUG=true
