# ═══════════════════════════════════════════════════════════════
# StockSense Docker Environment — COPY THIS TO backend/.env
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL=sqlite:///./data/stocksense.db

# JWT Auth
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API (free tier — https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter Fallback (free tier — https://openrouter.ai/)
OPENROUTER_API_KEY=your-openrouter-key-here

# WhatsApp Bot (Docker internal URL — auto-set by docker-compose)
WHATSAPP_BOT_URL=http://localhost:3001

# App Settings
APP_NAME=StockSense
APP_VERSION=1.0.0
DEBUG=true
